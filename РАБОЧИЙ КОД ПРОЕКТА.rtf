async def send_verdict(message: Message, state: FSMContext, verdict: dict, user_id: int, language: str):\
    log_verdict(user_id, verdict["pattern_label"], language)\
    \
    text = f"
\f1 \uc0\u55357 \u56522 
\f0  **\{verdict['pattern_label']\}**\\n\\n"\
    text += f"\{verdict['analysis']\}\\n\\n"\
    text += f"
\f1 \uc0\u9889 
\f0  **\{verdict['immediate_technique']['label']\}**: \{verdict['immediate_technique']['name']\}\\n"\
    \
    for i, step in enumerate(verdict['immediate_technique']['steps'], 1):\
        text += f"\{i\}. \{step\}\\n"\
    \
    text += f"\\n
\f1 \uc0\u55357 \u56481 
\f0  \uc0\u1055 \u1088 \u1080 \u1084 \u1077 \u1088 : \{verdict['immediate_technique']['example']\}\\n\\n"\
    text += "
\f1 \uc0\u55357 \u56523 
\f0  **\uc0\u1057 \u1090 \u1088 \u1072 \u1090 \u1077 \u1075 \u1080 \u1103 :**\\n"\
    \
    for i, action in enumerate(verdict['strategy'], 1):\
        text += f"\\n\{i\}. \{action['action']\}\\n"\
        text += f"   \uc0\u1052 \u1077 \u1093 \u1072 \u1085 \u1080 \u1079 \u1084 : \{action['mechanism']\}\\n"\
        text += f"   \uc0\u1050 \u1088 \u1080 \u1090 \u1077 \u1088 \u1080 \u1081 : \{action['criterion']\}\\n"\
    \
    await message.answer(text, parse_mode="Markdown")\
    \
    await storage.clear_session(user_id)\
    await state.clear()\
    \
    end_msg = SESSION_ENDED_MESSAGES.get(language, SESSION_ENDED_MESSAGES["en"])\
    await message.answer(end_msg)\
