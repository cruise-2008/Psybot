\f1 \uc0\u55356 \u56823 \u55356 \u56826 
\f0  \uc0\u1056 \u1091 \u1089 \u1089 \u1082 \u1080 \u1081 ", callback_data="lang_ru"),\
        ]\
    ])\
\
def get_consent_keyboard(lang: str):\
    consent_text = \{\
        "en": "
\f1 \uc0\u9989 
\f0  I agree",\
        "ru": "
\f1 \uc0\u9989 
\f0  \uc0\u1057 \u1086 \u1075 \u1083 \u1072 \u1089 \u1077 \u1085 ",\
        "es": "
\f1 \uc0\u9989 
\f0  Acepto",\
        "fr": "
\f1 \uc0\u9989 
\f0  J'accepte",\
        "de": "
\f1 \uc0\u9989 
\f0  Ich stimme zu"\
    \}\
    return InlineKeyboardMarkup(inline_keyboard=[\
        [InlineKeyboardButton(text=consent_text.get(lang, "
\f1 \uc0\u9989 
\f0  I agree"), callback_data="consent_yes")]\
